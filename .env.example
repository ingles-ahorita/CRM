# Copy to `.env.local` and fill in (Vite requires VITE_ prefix for client-exposed vars)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only (Zoom webhook, etc.). Never prefix with VITE_ — do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — server-only, used by /api/crm-ai-query
OPENAI_API_KEY=

# Business timezone for the AI chat (IANA name). Hardcoded to UTC in crm-ai-query.js.
